# URL publique du site (utilisée pour le SEO, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://www.aiglonsroyaux.com

# Lien vers le logiciel de gestion scolaire externe (bouton "S'inscrire")
NEXT_PUBLIC_ENROLLMENT_URL=https://gestion.aiglonsroyaux.com

# Resend (https://resend.com) — envoi des emails des formulaires Admissions & Contact
# Sans cette clé, les formulaires fonctionnent en mode démo : les soumissions sont
# simplement journalisées dans la console serveur au lieu d'être envoyées par email.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Site Aiglons Royaux <contact@aiglonsroyaux.com>"
